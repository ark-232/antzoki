# Copy to .env and fill in. Loaded with `node --env-file=.env ...` so the value
# never enters the shell history or the Claude Code context.

# ElevenLabs API key. Without it the pipeline uses the macOS `say` voice (great
# for iterating; not the deliverable voice).
ELEVENLABS_API_KEY=

# Optional: pin a specific narrator voice (otherwise a neutral default is used).
# ELEVENLABS_VOICE_ID=

# Optional: override the app URL from demo.json at run time.
# APP_URL=http://127.0.0.1:5173
